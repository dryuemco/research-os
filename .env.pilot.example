APP_ENV=pilot
APP_DEBUG=false
DOCS_ENABLED=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_PUBLIC_URL=https://your-render-api.onrender.com
DATABASE_URL=<render-provided-database-url>
LOG_LEVEL=INFO
INTERNAL_API_KEY=<set-strong-secret>
ARTIFACT_DOWNLOAD_SECRET=<set-strong-secret>
# IMPORTANT: never use dev defaults for secrets in pilot/prod.
ALLOWED_ORIGINS=https://your-org.github.io
RETRIEVAL_DEFAULT_MODE=hybrid
RETRIEVAL_LEXICAL_WEIGHT=0.6
RETRIEVAL_VECTOR_WEIGHT=0.4
ARTIFACT_STORAGE_BACKEND=db_fallback
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=<optional>
OPERATIONAL_SCHEDULER_ENABLED=true
OPERATIONAL_SCHEDULER_TICK_SECONDS=60
