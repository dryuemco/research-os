APP_NAME=Research Proposal OS
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/research_os
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=UTC
MODEL_ROUTING_POLICY_PATH=./config/model_routing_policy.example.json
DEV_INGESTION_SOURCE=funding_call_scaffold
DECOMPOSITION_POLICY_PATH=./config/decomposition_policy.example.json
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=

INTERNAL_API_KEY=dev-internal-key
RETRIEVAL_BACKEND=lexical
ARTIFACT_STORAGE_BACKEND=local_fs
ARTIFACT_STORAGE_ROOT=./artifacts
ARTIFACT_DOWNLOAD_SECRET=dev-artifact-download-secret
ARTIFACT_DOWNLOAD_TTL_SECONDS=300
OPERATIONAL_SCHEDULER_ENABLED=true
OPERATIONAL_SCHEDULER_TICK_SECONDS=60
OPERATIONAL_SOURCE_FIXTURE_PATH=./config/dev_source_payloads.example.json
